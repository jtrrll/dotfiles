layout {
  default_tab_template {
    pane {
      borderless true
      plugin {
        location "zellij:tab-bar"
      }
      size 1
    }
    children
    pane {
      borderless true
      plugin {
        location "zellij:status-bar"
      }
      size 2
    }
  }
  tab name="workspace" focus=true split_direction="vertical" {
    pane size="50%" {
      pane {
        name "shell"
        size "75%"
        focus true
        command "bash"
        args "-c" "nix develop . --impure -c $SHELL"
      }
      pane {
        name "nix repl"
        size "25%"
        command "nix"
        args "repl"
      }
    }
    pane {
      name "assistant"
      size "25%"
      command "nix"
      args "develop" "." "--impure" "-c" "opencode"
    }
    pane size="25%" {
      pane {
        name "git status"
        size "40%"
        command "watch"
        args "--interval" "10" "--no-title" "--color" "git" "-c" "color.ui=always" "status" "--short"
      }
      pane {
        name "just fmt"
        size "20%"
        command "nix"
        args "develop" "." "--impure" "-c" "just" "fmt"
        start_suspended true
      }
      pane {
        name "nix flake check"
        size "40%"
        command "nix"
        args "flake" "check" "--impure"
        start_suspended true
      }
    }
  }
  tab name="agent" {
    pane {
      name "agent"
      command "nix"
      args "develop" "." "--impure" "-c" "opencode"
      start_suspended true
    }
  }
}
